{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Doodle",
  "version": "0.1.0",
  "identifier": "com.doodle.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1422",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "widget",
        "title": "嘟豆 - Doodle",
        "width": 1440,
        "height": 900,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "resizable": true,
        "skipTaskbar": true,
        "center": true
      },
      {
        "label": "panel",
        "title": "嘟豆 · 主面板",
        "width": 800,
        "height": 600,
        "decorations": true,
        "visible": false,
        "center": true
      },
      {
        "label": "aichat",
        "title": "嘟豆 · AI 助手",
        "width": 500,
        "height": 600,
        "decorations": true,
        "visible": false,
        "center": true
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
